"""
Standalone diagnostic. Runs ONE utterance through streaming detect intent
with debugging info enabled, dumps the full response, and reports exactly
where headIntent / subIntent appear (if at all).

Fill in the 4 values below and run:  python diagnose_one.py
"""
import json
import uuid
from google.cloud import dialogflowcx_v3beta1 as dialogflow
from google.protobuf.json_format import MessageToDict

# ─── FILL THESE IN ──────────────────────────────────────────────────────────
AGENT_ID  = "projects/PROJECT/locations/LOCATION/agents/AGENT_UUID"  # full path
UTTERANCE = "appointment"     # the same utterance you test manually
LANGUAGE  = "en"
# ────────────────────────────────────────────────────────────────────────────

parts = AGENT_ID.split("/")
project_id, location, agent_uuid = parts[1], parts[3], parts[5]

api_endpoint = ("dialogflow.googleapis.com:443" if location == "global"
                else f"{location}-dialogflow.googleapis.com:443")
client = dialogflow.SessionsClient(client_options={"api_endpoint": api_endpoint})
session_path = client.session_path(project_id, location, agent_uuid, str(uuid.uuid4()))


def find_all_paths(obj, target_key, path=""):
    """Return every JSON path where target_key appears, with its value."""
    hits = []
    if isinstance(obj, dict):
        for k, v in obj.items():
            here = f"{path}.{k}"
            if k == target_key:
                hits.append((here, v))
            hits += find_all_paths(v, target_key, here)
    elif isinstance(obj, list):
        for i, item in enumerate(obj):
            hits += find_all_paths(item, target_key, f"{path}[{i}]")
    return hits


def run(enable_debug):
    def gen():
        yield dialogflow.StreamingDetectIntentRequest(
            session=session_path,
            query_input=dialogflow.QueryInput(
                text=dialogflow.TextInput(text=UTTERANCE),
                language_code=LANGUAGE,
            ),
            enable_debugging_info=enable_debug,
        )
    merged = {}
    responses = client.streaming_detect_intent(requests=gen())
    for i, resp in enumerate(responses):
        merged[f"response_{i}"] = MessageToDict(resp._pb)
    return merged


print(f"Utterance : {UTTERANCE}")
print(f"Session   : {session_path}\n")

print("=== STREAMING (enable_debugging_info=True) ===")
data = run(True)

fname = "streaming_dump.json"
with open(fname, "w") as f:
    json.dump(data, f, indent=2, default=str)
print(f"Full response written to {fname}\n")

# Top-level shape
for rkey, rval in data.items():
    print(f"{rkey} top-level keys: {list(rval.keys())}")
    if "debuggingInfo" in rval:
        print(f"  debuggingInfo keys: {list(rval['debuggingInfo'].keys())}")
    dir_ = rval.get("detectIntentResponse", {})
    qr = dir_.get("queryResult", {})
    if qr:
        print(f"  queryResult keys: {list(qr.keys())}")
        print(f"  queryResult.parameters: {qr.get('parameters', {})}")
        if "diagnosticInfo" in qr:
            print(f"  diagnosticInfo keys: {list(qr['diagnosticInfo'].keys())}")
print()

for key in ("headIntent", "subIntent"):
    hits = find_all_paths(data, key)
    if hits:
        print(f"'{key}' FOUND at:")
        for p, v in hits:
            print(f"    {p} = {v!r}")
    else:
        print(f"'{key}' NOT FOUND anywhere in the response.")
print()

# Also try the field name in snake_case, in case MessageToDict preserved it
for key in ("head_intent", "sub_intent"):
    hits = find_all_paths(data, key)
    if hits:
        print(f"'{key}' (snake_case) FOUND at:")
        for p, v in hits:
            print(f"    {p} = {v!r}")

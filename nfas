"""
Fourth diagnostic: compares the SAME utterance WITHOUT current_playbook
(normal agent entry / flow path) against the full Execution Sequence, and
hunts for headIntent / subIntent in the session parameters of every step.

Run:  python diagnose_four.py
"""
import json
import uuid
import configparser
from google.cloud import dialogflowcx_v3beta1 as dialogflow
from google.protobuf.json_format import MessageToDict

config = configparser.ConfigParser()
config.read("configPlayBook1.properties")
agent_id      = config.get("dialogflow", "agent_id")
language_code = config.get("input", "language_code", fallback="en")
UTTERANCE = "claims"   # change to any single utterance you test manually

parts = agent_id.split("/")
project_id, location, agent_uuid = parts[1], parts[3], parts[5]
api_endpoint = ("dialogflow.googleapis.com:443" if location == "global"
                else f"{location}-dialogflow.googleapis.com:443")
client = dialogflow.SessionsClient(client_options={"api_endpoint": api_endpoint})
session_path = client.session_path(project_id, location, agent_uuid, str(uuid.uuid4()))

# NOTE: NO query_params / NO current_playbook -- normal agent entry point
request = dialogflow.DetectIntentRequest(
    session=session_path,
    query_input=dialogflow.QueryInput(
        text=dialogflow.TextInput(text=UTTERANCE),
        language_code=language_code,
    ),
)
response = client.detect_intent(request=request)
full = MessageToDict(response._pb)
qr = full.get("queryResult", {})

print(f"Utterance : {UTTERANCE}  (NO current_playbook)\n")
print("currentFlow :", qr.get("currentFlow", {}).get("displayName", "(none)"))
print("currentPage :", qr.get("currentPage", {}).get("displayName", "(none)"))
print("match type  :", qr.get("match", {}).get("matchType"))
print("response    :", [t for m in qr.get("responseMessages", [])
                        for t in m.get("text", {}).get("text", [])])
print()

exec_seq = qr.get("diagnosticInfo", {}).get("Execution Sequence", [])
print(f"Execution Sequence has {len(exec_seq)} steps")
print()

# Show every SessionParameters block and whether it has head/sub intent
def walk_params(o, found):
    if isinstance(o, dict):
        for k, v in o.items():
            if k in ("SessionParameters", "SessionParameters(Updated)") and isinstance(v, dict):
                if "headIntent" in v or "subIntent" in v:
                    found.append({kk: v.get(kk) for kk in ("headIntent", "subIntent") if kk in v})
            walk_params(v, found)
    elif isinstance(o, list):
        for x in o:
            walk_params(x, found)

found = []
walk_params(full, found)
if found:
    print("=== headIntent / subIntent FOUND in session params ===")
    for f in found:
        print("   ", f)
else:
    print("=== headIntent / subIntent NOT in any session params ===")

with open("noplaybook_dump.json", "w") as f:
    json.dump(full, f, indent=2, default=str)
print("\nFull response written to noplaybook_dump.json")
